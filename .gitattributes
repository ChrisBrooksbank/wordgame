# Auto detect text files and normalize line endings
* text=auto

# Explicitly declare text files
*.md text diff=markdown
*.txt text
*.json text
*.js text
*.ts text
*.tsx text
*.jsx text
*.css text
*.html text
*.yml text
*.yaml text
*.sh text eol=lf

# Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
